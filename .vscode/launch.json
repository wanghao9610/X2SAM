    "configurations": [
        {
            "name": "x2sam: train",
            "type": "debugpy",
            "request": "launch",
            "justMyCode": false,
            "console": "integratedTerminal",
            "program": "x2sam/x2sam/tools/train.py",
            "args": [
                "x2sam/x2sam/configs/x2sam/s3_train/x2sam_qwen3_4b_siglip2_so400m_p14_384_sam2.1_hiera_large_m2f_gpu16_s3_lora.py",
                "--work-dir",
                "wkdrs/vs_debug",
                "--resume",
                "auto",
                "--deepspeed",
                "x2sam/x2sam/configs/deepspeed/deepspeed_zero2.json",
                "--seed",
                "1024",
                "--cfg-options",
                "model.freeze_llm=True",
                "model.freeze_vlm=True"
            ],
            "env": {
                "DEBUG_MODE": "true",
                "DEBUG_ITEM": "64",
                "CUDA_VISIBLE_DEVICES": "0",
                "ROOT_DIR": "${workspaceFolder}/",
                "DATA_DIR": "${workspaceFolder}/datas/",
                "INIT_DIR": "${workspaceFolder}/inits/",
                "CUDA_HOME": "your_cuda_path",
                "PATH": "$CUDA_HOME/bin:$PATH",
                "LD_LIBRARY_PATH": "$CUDA_HOME/lib64:$LD_LIBRARY_PATH",
                "PYTHONPATH": "${workspaceFolder}/x2sam:${env:PYTHONPATH}",
                "HF_HOME": "{workspaceFolder}/inits/huggingface",
                "TRANSFORMERS_OFFLINE": "1",
                "TOKENIZERS_PARALLELISM": "false",
                "USE_TRITON_KERNEL": "1",
                "PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "40",
                "PYDEVD_DISABLE_FILE_VALIDATION": "1",
                "MASTER_PORT": "29511",
                "DS_BUILD_OPS": "0"
            },
        },
